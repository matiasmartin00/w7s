{
  "name": "w7s",
  "version": "0.1.0",
  "description": "OpenCode server plugin for sequential YAML workflow execution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
