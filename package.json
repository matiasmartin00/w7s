  "dependencies": {
    "@opencode-ai/plugin": "^1.3.10",
    "yaml": "^2.7.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.8.0",
